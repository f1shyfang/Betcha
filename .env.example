# Monolithic Next.js environment variables
# Copy this to .env.local and fill in your values.

# Optional API base override. Leave empty for same-origin /api routes.
NEXT_PUBLIC_API_URL=

# Postgres (used by /api/markets/[id]/resolve and migrations)
DATABASE_URL=postgres://localhost:5432/betcha_dev

# Supabase server credentials (used by /api/waitlist and auth lookup)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase browser credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
